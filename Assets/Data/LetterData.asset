  m_Name: LetterData
  m_EditorClassIdentifier: Assembly-CSharp::LetterData
  _levels:
  - title1: "\u0423\u0412\u0415\u0414\u041E\u041C\u041B\u0415\u041D\u0418\u0415 \u041E
      \u041D\u0410\u0421\u041B\u0415\u0414\u0421\u0422\u0412\u0415"
    content1: "\u041F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E,\\n\u041C\u0435\u043D\u044F
      \u0437\u043E\u0432\u0443\u0442 \u043C\u0438\u0441\u0442\u0435\u0440 \u0411\u044D\u0434
      \u0424\u0440\u043E\u0434, \u044F \u044F\u0432\u043B\u044F\u044E\u0441\u044C
      \u043F\u043E\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u043C \u0412\u0430\u0448\u0435\u0433\u043E
      \u0442\u0440\u043E\u044E\u0440\u043E\u0434\u043D\u043E\u0433\u043E \u0434\u044F\u0434\u044E\u0448\u043A\u0438
      \u041C\u0430\u0440\u0448\u0430\u043B\u043B\u0430 \u0414\u0430\u043A\u043A\u0430,
      \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0430 \u0410\u043B\u043C\u0430\u0437\u043D\u044B\u0445
      \u0448\u0430\u0445\u0442 \u0432 \u041D\u0438\u0433\u0435\u0440\u0438\u0438. 
      \u0421 \u043F\u0440\u0438\u0441\u043A\u043E\u0440\u0431\u0438\u0435\u043C \u0441\u043E\u043E\u0431\u0449\u0430\u044E,
      \u0447\u0442\u043E \u0412\u0430\u0448 \u0434\u043E\u0441\u0442\u043E\u043F\u043E\u0447\u0442\u0435\u043D\u043D\u044B\u0439
      \u0434\u044F\u0434\u044E\u0448\u043A\u0430 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
      \u0438 \u043D\u0435 \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435
      \u0441\u0435\u0431\u044F \u043D\u0430\u0441\u043B\u0435\u0434\u043D\u0438\u043A\u043E\u0432.
      \u041F\u0440\u043E\u0432\u0435\u0434\u044F \u043C\u043D\u043E\u0433\u043E \u043B\u0435\u0442
      \u0432 \u043F\u043E\u0438\u0441\u043A\u0430\u0445, \u044F \u0432\u044B\u044F\u0441\u043D\u0438\u043B,
      \u0447\u0442\u043E \u0432\u044B \u044F\u0432\u043B\u044F\u0435\u0442\u0435\u0441\u044C
      \u0435\u0433\u043E \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0438\u043C \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C
      \u0438 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
      \u043D\u0430\u0441\u043B\u0435\u0434\u043D\u0438\u043A\u043E\u043C \u0435\u0433\u043E
      \u0430\u043B\u043C\u0430\u0437\u043D\u044B\u0445 \u0448\u0430\u0445\u0442.
      \u0413\u043E\u0442\u043E\u0432\u044B \u043B\u0438 \u0432\u044B \u043F\u0440\u0438\u043D\u044F\u0442\u044C
      \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E \u0438 \u0441\u0442\u0430\u0442\u044C
      \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0435\u043C \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
      \u0448\u0430\u0445\u0442 \u0432 \u041D\u0438\u0433\u0435\u0440\u0438\u0438? 
      \\n\u0418\u0441\u043A\u0440\u0435\u043D\u043D\u0435 \u0432\u0430\u0448, Bad
      Froud "
    title2: "\u0418\u0417\u0412\u0415\u0429\u0415\u041D\u0418\u0415"
    content2: "\u0414\u043E\u0440\u043E\u0433\u043E\u0439 \u0413\u0443\u0441\u044C,
      \\n\u042F \u0440\u0430\u0434 \u0447\u0442\u043E \u0442\u044B \u043F\u0440\u0438\u043D\u044F\u043B
      \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E! \u0428\u0430\u0445\u0442\u044B
      \u043E\u0447\u0435\u043D\u044C \u0432\u0430\u0436\u043D\u044B \u0434\u043B\u044F
      \u043C\u0435\u043D\u044F \u0438 \u0442\u0435\u043F\u0435\u0440\u044C \u043E\u043D\u0438
      \u0431\u0443\u0434\u0443\u0442 \u0432 \u043D\u0430\u0434\u0435\u0436\u043D\u044B\u0445
      \u0440\u0443\u043A\u0430\u0445. \u041D\u0430\u0434\u0435\u044E\u0441\u044C,
      \u0442\u0435\u0431\u044F \u043D\u0435 \u043E\u0433\u043E\u0440\u0447\u0438\u0442
      \u0442\u043E\u0442 \u0444\u0430\u043A\u0442, \u0447\u0442\u043E \u0443 \u0448\u0430\u0445\u0442\u044B
      \u0435\u0441\u0442\u044C \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0430\u044F
      \u0437\u0430\u0434\u043E\u043B\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u044C,
      \u043D\u043E \u044F \u0443\u0432\u0435\u0440\u0435\u043D, \u0447\u0442\u043E
      \u0442\u044B \u0441 \u043D\u0435\u0439 \u0441\u043F\u0440\u0430\u0432\u0438\u0448\u044C\u0441\u044F.
      \u0423\u0434\u0430\u0447\u0438! \\n\u0422\u0432\u043E\u0439 \u043B\u044E\u0431\u044F\u0449\u0438\u0439
      \u0434\u044F\u0434\u044F, \\nMarshall Duck "
  - title1: "\u041F\u0418\u0421\u042C\u041C\u041E"
    content1: "\u0414\u043E\u0440\u043E\u0433\u043E\u0439 \u0433\u0443\u0441\u0451\u043D\u043E\u043A,
      \\n\u0414\u0430\u0432\u043D\u043E \u0442\u0435\u0431\u044F \u043D\u0435 \u0441\u043B\u044B\u0448\u0430\u043B\u0430,
      \u043D\u0430\u0434\u0435\u044E\u0441\u044C \u0443 \u0442\u0435\u0431\u044F
      \u0432\u0441\u0435 \u0445\u043E\u0440\u043E\u0448\u043E, \u0438 \u0442\u0432\u043E\u044F
      \u043F\u043E\u0435\u0437\u0434\u043A\u0430 \u0432 \u041D\u0438\u0433\u0435\u0440\u0438\u044E
      \u043F\u0440\u043E\u0448\u043B\u0430 \u0443\u0441\u043F\u0435\u0448\u043D\u043E. 
      \u041A\u0430\u043A \u0442\u044B \u0437\u043D\u0430\u0435\u0448\u044C, \u044F
      \u043D\u0435\u0434\u0430\u0432\u043D\u043E \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436,
      \u043D\u043E \u043A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E
      \u043C\u043E\u0439 \u043C\u0443\u0436 \u0438\u0441\u0447\u0435\u0437. \u041F\u043E\u044D\u0442\u043E\u043C\u0443
      \u043F\u0440\u043E\u0448\u0443 \u0442\u0435\u0431\u044F \u043F\u0440\u0438\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
      \u0437\u0430 \u043C\u043E\u0438\u043C \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0438\u043C
      \u0437\u0430\u0432\u043E\u0434\u0438\u043A\u043E\u043C \u043F\u043E\u043A\u0430
      \u044F \u0438\u0449\u0443 \u043C\u043E\u0435\u0433\u043E \u0434\u043E\u0440\u043E\u0433\u043E\u0433\u043E
      \u0442\u043E\u0432\u0430\u0440\u0438\u0449\u0430 \u0411\u0435\u043D\u0434\u0435\u0440\u0430.
      \u041D\u0430\u0434\u0435\u044E\u0441\u044C \u043C\u043E\u044F \u043F\u0440\u043E\u0441\u044C\u0431\u0430
      \u0442\u0435\u0431\u044F \u043D\u0435 \u0437\u0430\u0442\u0440\u0443\u0434\u043D\u0438\u0442.
      \\n\\n\u0421 \u043B\u044E\u0431\u043E\u0432\u044C\u044E, \u0442\u0432\u043E\u044F
      \u0442\u0451\u0442\u044F \\n\u041C\u0430\u0434\u0430\u043C \u0413\u0440\u0438\u0446\u0430\u0446\u0443\u0435\u0432\u0430"
    title2: "\u041A\u0420\u0418\u041C\u0418\u041D\u0410\u041B\u042C\u041D\u0410\u042F
      \u0425\u0420\u041E\u041D\u0418\u041A\u0410"
    content2: "\u041D\u0435 \u0443\u0441\u043F\u0435\u043B\u0430 \u043E\u0442\u0433\u0440\u0435\u043C\u0435\u0442\u044C
      \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u0430\u044F \u0441\u0432\u0430\u0434\u044C\u0431\u0430
      \u041C\u0430\u0434\u0430\u043C \u0413\u0440\u0438\u0446\u0430\u0446\u0443\u0435\u0432\u043E\u0439
      \u0438 \u041E\u0441\u0442\u0430\u043F\u0430 \u0411\u0435\u043D\u0434\u0435\u0440\u0430,
      \u043A\u0430\u043A \u0432\u044B\u044F\u0441\u043D\u0438\u043B\u043E\u0441\u044C,
      \u0447\u0442\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440
      \u0438 \u0435\u0433\u043E \u043F\u043E\u0434\u0435\u043B\u044C\u043D\u0438\u043A
      \u041A\u0438\u0441\u0430 \u0443\u043A\u0440\u0430\u043B\u0438 \u0443 \u043D\u043E\u0432\u043E\u0438\u0441\u043F\u0435\u0447\u0435\u043D\u043D\u043E\u0439
      \u043D\u0435\u0432\u0435\u0441\u0442\u044B \u0435\u0435 \u0441\u0431\u0435\u0440\u0435\u0436\u0435\u043D\u0438\u044F
      \u0438 \u043F\u043E\u0432\u0440\u0435\u0434\u0438\u043B\u0438 \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E.
      \u0422\u0435\u043F\u0435\u0440\u044C \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B
      \u0435\u0451 \u0437\u0430\u0432\u043E\u0434\u0430 \u043F\u0440\u0438\u0434\u0435\u0442\u0441\u044F
      \u043F\u0440\u0438\u043B\u043E\u0436\u0438\u0442\u044C \u0443\u0441\u0438\u043B\u0438\u044F
      \u0438 \u0432\u044B\u043F\u043B\u0430\u0442\u0438\u0442\u044C \u0434\u043E\u043B\u0433.
      \u0418\u043D\u0430\u0447\u0435 \u0438\u0437-\u0437\u0430 \u0434\u043E\u043B\u0433\u043E\u0432
      \u0437\u0430\u0432\u043E\u0434 \u043F\u0440\u0438\u0434\u0435\u0442\u0441\u044F
      \u0437\u0430\u043A\u0440\u044B\u0442\u044C, \u043F\u0440\u043E\u0434\u0443\u043A\u0446\u0438\u044E
      \u043F\u0440\u043E\u0434\u0430\u0442\u044C \u0441 \u0430\u0443\u043A\u0446\u0438\u043E\u043D\u0430,
      \u0430 \u0435\u0451 \u043D\u043E\u0432\u044B\u0439 \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u044E\u0449\u0438\u0439
      \u0413\u0443\u0441\u044C \u0441\u0442\u0430\u043D\u0435\u0442 \u0431\u0430\u043D\u043A\u0440\u043E\u0442\u043E\u043C.
      \u0423\u0432\u0430\u0436\u0430\u0435\u043C\u044B\u0435 \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u0438,
      \u043F\u043E\u0436\u0435\u043B\u0430\u0435\u043C \u0443\u0434\u0430\u0447\u0438
      \u0413\u0443\u0441\u044E."
  - title1: "\u041F\u0440\u0438\u0432\u0435\u0442 \u043F\u0440\u0438\u0432\u0435\u0442!"
    content1: "\u041F\u0440\u0438\u0432\u0435\u0442, \u0413\u0443\u0441\u044C! \\n\u041A\u0430\u043A
      \u0434\u0435\u043B\u0430? \u0414\u0430\u0432\u043D\u043E \u0441 \u0442\u043E\u0431\u043E\u0439
      \u043D\u0435 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438\u0441\u044C((
      \u041C\u043D\u0435 \u043D\u0430\u0434\u043E \u0441\u044A\u0435\u0437\u0434\u0438\u0442\u044C
      \u043F\u043E \u0440\u0430\u0431\u043E\u0442\u0435 \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0443,
      \u0430 \u0442\u043E \u0442\u0443\u0442 \u043A\u0430\u043A\u0430\u044F-\u0442\u043E
      \u043F\u0435\u043D\u0441\u0438\u043E\u043D\u0435\u0440\u043A\u0430 \u043E\u0431\u0432\u0438\u043D\u044F\u0435\u0442
      \u043C\u0435\u043D\u044F \u0432 \u043A\u0430\u043A\u043E\u043C-\u0442\u043E
      \u0441\u043A\u0430\u043C\u0435 =_=\\n \u0420\u0430\u0441\u0441\u043A\u0430\u0436\u0443
      \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435, \u043A\u043E\u0433\u0434\u0430
      \u0432\u0435\u0440\u043D\u0443\u0441\u044C. \u0410 \u043F\u043E\u043A\u0430
      \u043C\u043D\u0435 \u043D\u0435\u0442 \u043F\u0443\u0442\u0438 \u0434\u043E\u043C\u043E\u0439\u2026
      \u041F\u0435\u0440\u0435\u0437\u0432\u043E\u043D\u0438 \u043C\u043D\u0435,
      \u043A\u043E\u0433\u0434\u0430 \u0441\u043C\u043E\u0436\u0435\u0448\u044C,
      \u0443 \u043C\u0435\u043D\u044F \u0441\u0432\u044F\u0437\u044C \u043B\u043E\u0432\u0438\u0442
      \u0434\u0430\u0436\u0435 \u043D\u0430 \u043F\u0430\u0440\u043A\u043E\u0432\u043A\u0435!
      \\nP.s.: \u043F\u0440\u0438\u0441\u043C\u043E\u0442\u0440\u0438 \u0437\u0430
      \u043C\u043E\u0438\u043C\u0438 \u043A\u0440\u0438\u043F\u0442\u043E \u044F\u0439\u0446\u0430\u043C\u0438.
      \\n \\n\u0422\u0432\u043E\u0439 \u0431\u0440\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u043A,
      \\nTom Chick Olland"
    title2: "\u041F\u0443 \u043F\u0443 \u043F\u0443..."
    content2: "\u0427\u0442\u043E-\u0442\u043E \u0442\u0435\u043C\u0430 \u0441 \u043A\u0440\u0438\u043F\u0442\u043E
      \u044F\u0439\u0446\u0430\u043C\u0438 \u043D\u0435 \u0437\u0430\u043B\u0435\u0442\u0435\u043B\u0430
      \u0422\u0435\u043F\u0435\u0440\u044C \u0442\u0435\u0431\u044F \u0438\u0449\u0435\u0442
      \u0442\u043E\u043B\u043F\u0430 \u0440\u0430\u0437\u0433\u043D\u0435\u0432\u0430\u043D\u043D\u044B\u0445
      \u0438\u043D\u0432\u0435\u0441\u0442\u043E\u0440\u043E\u0432 \u0438 \u043E\u0434\u043D\u0430
      \u043D\u0435\u043F\u0440\u0438\u044F\u0442\u043D\u0430\u044F \u043F\u0435\u043D\u0441\u0438\u043E\u043D\u0435\u0440\u043A\u0430
      \u043F\u043E\u0445\u043E\u0436\u0430\u044F \u043D\u0430 \u0413\u0440\u0438\u043D\u0447\u0430.
      \\n\u0411\u0440\u0430\u0442 \u0432\u0435\u0440\u043D\u0435\u0442\u0441\u044F
      \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0441\u043B\u0435 \u0420\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u0430
      \u0434\u043E\u043C\u043E\u0439, \u0430 \u043F\u043E\u043A\u0430 \u0441 \u0434\u043E\u043B\u0433\u043E\u043C
      \u043F\u0440\u0438\u0434\u0435\u0442\u0441\u044F \u0440\u0430\u0437\u0431\u0438\u0440\u0430\u0442\u044C\u0441\u044F
      \u0442\u0435\u0431\u0435!  \\nP.s.: \u0414\u0435\u0434\u0443\u0448\u043A\u0435
      \u041C\u0430\u0433\u0434\u0430\u043A\u0443 \u043D\u0435 \u0437\u0432\u043E\u043D\u0438,
      \u043E\u043D \u043D\u0435 \u043F\u043E\u043C\u043E\u0436\u0435\u0442. "
